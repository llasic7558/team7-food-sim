{
	auto_https off
	admin off
}

:8000 {
	reverse_proxy {
		# Resolve the Docker Compose service name repeatedly so scaled
		# driver-service-app replicas are discovered without editing this file.
		dynamic a driver-service-app 8000 {
			refresh 2s
			resolvers 127.0.0.11
			versions ipv4
		}

		lb_policy round_robin
		lb_try_duration 5s
		lb_try_interval 250ms
	}
}
